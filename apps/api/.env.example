# Supabase Postgres connection (Settings → Database → Connection string → URI)
# Leave unset to use local SQLite (apps/api/data/projectlab.db)
DATABASE_URL=postgresql://postgres.xxxxxxxxxxxx:YOUR_PASSWORD@aws-0-ap-south-1.pooler.supabase.com:5432/postgres

# JWT secret — change this in production!
JWT_SECRET=change-me-to-a-long-random-string

# SMTP for OTP emails (Gmail: smtp.gmail.com + app password; Brevo: smtp-relay.brevo.com)
# When set, OTP goes by email; when unset, OTP is returned in the API response (dev mode)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=yourapp@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM=ProjectLab <yourapp@gmail.com>
