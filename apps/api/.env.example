# Supabase Postgres connection (Settings → Database → Connection string → URI)
# Leave unset to use local SQLite (apps/api/data/projectlab.db)
DATABASE_URL=postgresql://postgres.xxxxxxxxxxxx:YOUR_PASSWORD@aws-0-ap-south-1.pooler.supabase.com:5432/postgres

# JWT secret — change this in production!
JWT_SECRET=change-me-to-a-long-random-string

# --- Email OTP delivery (pick ONE) ---
# Option 1 (RECOMMENDED for Render): Brevo HTTP API — works even where SMTP is blocked.
#   BREVO_API_KEY=xkeysib-xxxxxxxx
#   EMAIL_FROM=ProjectLab <you@yourverifiedsender.com>
#
# Option 2: SMTP (Gmail etc.) — NOTE: Render free tier often blocks outbound SMTP.
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=yourapp@gmail.com
#   SMTP_PASS=your-16-char-app-password
#   SMTP_FROM=ProjectLab <yourapp@gmail.com>

# Twilio Verify for phone (SMS) OTP. When set, OTP goes by SMS; when unset,
# OTP is returned in the API response (dev mode) so phone login still works.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
