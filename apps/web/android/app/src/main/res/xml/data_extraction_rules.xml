<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ (targetSdk 36) reads this instead of fullBackupContent.

  The app's data directory contains the WebView's localStorage, which holds the
  refresh token (projectlab-session-v1) and the cached financial plan
  (projectlab-state-in-v1). Neither should leave the device, so both cloud backup
  and device-to-device transfer are excluded wholesale rather than by allowlist —
  a new storage key should be private by default, not by remembering to add it here.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>
