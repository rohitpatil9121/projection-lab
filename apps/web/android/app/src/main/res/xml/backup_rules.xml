<?xml version="1.0" encoding="utf-8"?>
<!--
  Fallback for Android 11 and below (minSdk is 24), where dataExtractionRules is
  ignored. allowBackup="false" already disables backup on these versions; this file
  exists so the exclusion is explicit if backup is ever turned back on.
  See data_extraction_rules.xml for the reasoning.
-->
<full-backup-content>
    <exclude domain="root" path="." />
    <exclude domain="file" path="." />
    <exclude domain="database" path="." />
    <exclude domain="sharedpref" path="." />
    <exclude domain="external" path="." />
</full-backup-content>
